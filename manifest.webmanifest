{
  "name": "Dash K Express",
  "short_name": "Dash K",
  "description": "Independent Dash K Express moving and delivery app powered by MovingOS workflow technology.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#fbfcfa",
  "theme_color": "#0c7a63",
